# API Configuration — default points to the production backend.
# .env is committed with the production URL.
# Create .env.local (gitignored via *.local) to override for local development.

# Production backend (default):
VITE_API_URL=https://api.masld.scilicium.com

# For local development with a local backend running on port 8000,
# create a .env.local file with:
# VITE_API_URL=http://localhost:8000
