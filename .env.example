# API Configuration
# For local development: point to local backend
VITE_API_URL=http://localhost:8000

# For Vercel production deployment:
# Set this in Vercel Dashboard -> Settings -> Environment Variables
# VITE_API_URL=https://your-backend-url.com
# (Replace with your actual backend URL: ngrok tunnel, cloudflare tunnel, or public server)

# Example with ngrok tunnel:
# VITE_API_URL=https://abc123.ngrok.io

# Example with public server:
# VITE_API_URL=https://api.masldatlas.com
