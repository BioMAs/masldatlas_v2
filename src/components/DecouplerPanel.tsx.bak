import React, { useState } from 'react';
import { useMutation } from '@tanstack/react-query';
import { Network, Activity, BookOpen, Download } from 'lucide-react';

interface DecouplerPanelProps {
  deseqResults: any[];
  organism: string;
}

type AnalysisType = 'collectri' | 'progeny' | 'msigdb';

export const DecouplerPanel: React.FC<DecouplerPanelProps> = ({
  deseqResults,
  organism
}) => {
  const [activeTab, setActiveTab] = useState<AnalysisType>('collectri');
  const [selectedTF, setSelectedTF] = useState<string>('');
  const [selectedPathway, setSelectedPathway] = useState<string>('');
  const [selectedGeneSet, setSelectedGeneSet] = useState<string>('');

  // CollecTRI Analysis
  const collectriMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch('http://localhost:8000/api/decoupler/collectri', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ deseq_results: deseqResults, organism })
      });
      
      if (!response.ok) throw new Error('CollecTRI analysis failed');
      return response.json();
    }
  });

  // CollecTRI Volcano
  const volcanoMutation = useMutation({
    mutationFn: async (tf: string) => {
      const response = await fetch('http://localhost:8000/api/decoupler/collectri/volcano', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tf_name: tf, deseq_results: deseqResults })
      });
      
      if (!response.ok) throw new Error('Volcano plot failed');
      return response.json();
    }
  });

  // CollecTRI Network
  const networkMutation = useMutation({
    mutationFn: async (tf: string) => {
      const response = await fetch('http://localhost:8000/api/decoupler/collectri/network', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          tf_name: tf, 
          deseq_results: deseqResults,
          n_targets: 20
        })
      });
      
      if (!response.ok) throw new Error('Network plot failed');
      return response.json();
    }
  });

  // PROGENy Analysis
  const progenyMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch('http://localhost:8000/api/decoupler/progeny', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ deseq_results: deseqResults, organism })
      });
      
      if (!response.ok) throw new Error('PROGENy analysis failed');
      return response.json();
    }
  });

  // PROGENy Targets
  const progenyTargetsMutation = useMutation({
    mutationFn: async (pathway: string) => {
      const response = await fetch('http://localhost:8000/api/decoupler/progeny/targets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          pathway_name: pathway, 
          deseq_results: deseqResults,
          n_genes: 50
        })
      });
      
      if (!response.ok) throw new Error('Targets plot failed');
      return response.json();
    }
  });

  // MSigDB Analysis
  const msigdbMutation = useMutation({
    mutationFn: async () => {
      const response = await fetch('http://localhost:8000/api/decoupler/msigdb', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ deseq_results: deseqResults, organism })
      });
      
      if (!response.ok) throw new Error('MSigDB analysis failed');
      return response.json();
    }
  });

  // MSigDB Running Score
  const runningScoreMutation = useMutation({
    mutationFn: async (geneSet: string) => {
      const response = await fetch('http://localhost:8000/api/decoupler/msigdb/running-score', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          gene_set_name: geneSet, 
          deseq_results: deseqResults
        })
      });
      
      if (!response.ok) throw new Error('Running score plot failed');
      return response.json();
    }
  });

  const downloadImage = (base64: string, filename: string) => {
    const link = document.createElement('a');
    link.href = base64;
    link.download = filename;
    link.click();
  };

  return (
    <div className="bg-white rounded-lg shadow-lg p-6">
      <h2 className="text-2xl font-bold mb-4 text-gray-900">
        Decoupler Analysis
      </h2>

      <p className="text-sm text-gray-600 mb-6">
        Analyse avancée de régulation transcriptionnelle et d'activité des voies de signalisation
      </p>

      {/* Tabs */}
      <div className="flex gap-2 mb-6 border-b border-gray-200">
        <button
          onClick={() => setActiveTab('collectri')}
          className={`px-4 py-2 font-medium flex items-center gap-2 transition-colors ${
            activeTab === 'collectri'
              ? 'border-b-2 border-blue-600 text-blue-600'
              : 'text-gray-600 hover:text-gray-900'
          }`}
        >
          <Network className="w-4 h-4" />
          CollecTRI (TF)
        </button>
        
        <button
          onClick={() => setActiveTab('progeny')}
          className={`px-4 py-2 font-medium flex items-center gap-2 transition-colors ${
            activeTab === 'progeny'
              ? 'border-b-2 border-blue-600 text-blue-600'
              : 'text-gray-600 hover:text-gray-900'
          }`}
        >
          <Activity className="w-4 h-4" />
          PROGENy (Pathways)
        </button>
        
        <button
          onClick={() => setActiveTab('msigdb')}
          className={`px-4 py-2 font-medium flex items-center gap-2 transition-colors ${
            activeTab === 'msigdb'
              ? 'border-b-2 border-blue-600 text-blue-600'
              : 'text-gray-600 hover:text-gray-900'
          }`}
        >
          <BookOpen className="w-4 h-4" />
          MSigDB Hallmark
        </button>
      </div>

      {/* CollecTRI Tab */}
      {activeTab === 'collectri' && (
        <div className="space-y-4">
          <div>
            <button
              onClick={() => collectriMutation.mutate()}
              disabled={collectriMutation.isPending || deseqResults.length === 0}
              className="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed flex items-center gap-2"
            >
              {collectriMutation.isPending ? (
                <>
                  <div className="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                  Analyse en cours...
                </>
              ) : (
                <>
                  <Network className="w-5 h-5" />
                  Lancer l'analyse CollecTRI
                </>
              )}
            </button>
          </div>

          {collectriMutation.isSuccess && (
            <div className="space-y-4">
              <div className="bg-green-50 border border-green-200 rounded-lg p-4">
                <p className="text-green-800 font-medium">
                  ✅ {collectriMutation.data.n_tfs} facteurs de transcription analysés
                </p>
              </div>

              {/* Barplot */}
              <div className="border border-gray-200 rounded-lg p-4">
                <div className="flex justify-between items-center mb-2">
                  <h3 className="font-semibold text-gray-900">Top 25 Facteurs de Transcription</h3>
                  <button
                    onClick={() => downloadImage(collectriMutation.data.barplot_image, 'collectri_barplot.png')}
                    className="text-sm text-blue-600 hover:text-blue-700 flex items-center gap-1"
                  >
                    <Download className="w-4 h-4" />
                    Télécharger
                  </button>
                </div>
                <img 
                  src={collectriMutation.data.barplot_image} 
                  alt="CollecTRI Barplot"
                  className="w-full h-auto"
                />
              </div>

              {/* TF Selection for detailed plots */}
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  Sélectionner un TF pour visualisation détaillée
                </label>
                <select
                  value={selectedTF}
                  onChange={(e) => setSelectedTF(e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg"
                >
                  <option value="">-- Choisir un TF --</option>
                  {collectriMutation.data.tf_scores?.slice(0, 50).map((tf: any) => (
                    <option key={tf.index} value={tf.index}>
                      {tf.index} (score: {tf.score?.toFixed(3)})
                    </option>
                  ))}
                </select>
              </div>

              {selectedTF && (
                <div className="flex gap-2">
                  <button
                    onClick={() => volcanoMutation.mutate(selectedTF)}
                    disabled={volcanoMutation.isPending}
                    className="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700 disabled:bg-gray-300"
                  >
                    Volcano Plot
                  </button>
                  <button
                    onClick={() => networkMutation.mutate(selectedTF)}
                    disabled={networkMutation.isPending}
                    className="px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700 disabled:bg-gray-300"
                  >
                    Network Plot
                  </button>
                </div>
              )}

              {volcanoMutation.isSuccess && (
                <div className="border border-gray-200 rounded-lg p-4">
                  <h4 className="font-semibold mb-2">Volcano Plot - {selectedTF}</h4>
                  <img src={volcanoMutation.data.volcano_image} alt="Volcano" className="w-full" />
                </div>
              )}

              {networkMutation.isSuccess && (
                <div className="border border-gray-200 rounded-lg p-4">
                  <h4 className="font-semibold mb-2">Network - {selectedTF}</h4>
                  <img src={networkMutation.data.network_image} alt="Network" className="w-full" />
                </div>
              )}
            </div>
          )}
        </div>
      )}

      {/* PROGENy Tab */}
      {activeTab === 'progeny' && (
        <div className="space-y-4">
          <div>
            <button
              onClick={() => progenyMutation.mutate()}
              disabled={progenyMutation.isPending || deseqResults.length === 0}
              className="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-300 flex items-center gap-2"
            >
              {progenyMutation.isPending ? (
                <>
                  <div className="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                  Analyse en cours...
                </>
              ) : (
                <>
                  <Activity className="w-5 h-5" />
                  Lancer l'analyse PROGENy
                </>
              )}
            </button>
          </div>

          {progenyMutation.isSuccess && (
            <div className="space-y-4">
              <div className="bg-green-50 border border-green-200 rounded-lg p-4">
                <p className="text-green-800 font-medium">
                  ✅ {progenyMutation.data.n_pathways} voies analysées
                </p>
              </div>

              <div className="border border-gray-200 rounded-lg p-4">
                <div className="flex justify-between items-center mb-2">
                  <h3 className="font-semibold">Activité des Voies de Signalisation</h3>
                  <button
                    onClick={() => downloadImage(progenyMutation.data.barplot_image, 'progeny_barplot.png')}
                    className="text-sm text-blue-600 hover:text-blue-700 flex items-center gap-1"
                  >
                    <Download className="w-4 h-4" />
                    Télécharger
                  </button>
                </div>
                <img src={progenyMutation.data.barplot_image} alt="PROGENy Barplot" className="w-full" />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  Sélectionner une voie pour voir les gènes cibles
                </label>
                <select
                  value={selectedPathway}
                  onChange={(e) => setSelectedPathway(e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg"
                >
                  <option value="">-- Choisir une voie --</option>
                  {progenyMutation.data.pathway_scores?.map((pw: any) => (
                    <option key={pw.index} value={pw.index}>
                      {pw.index} (score: {pw.score?.toFixed(3)})
                    </option>
                  ))}
                </select>
              </div>

              {selectedPathway && (
                <button
                  onClick={() => progenyTargetsMutation.mutate(selectedPathway)}
                  disabled={progenyTargetsMutation.isPending}
                  className="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700"
                >
                  Afficher les Gènes Cibles
                </button>
              )}

              {progenyTargetsMutation.isSuccess && (
                <div className="border border-gray-200 rounded-lg p-4">
                  <h4 className="font-semibold mb-2">Gènes Cibles - {selectedPathway}</h4>
                  <img src={progenyTargetsMutation.data.targets_image} alt="Targets" className="w-full" />
                </div>
              )}
            </div>
          )}
        </div>
      )}

      {/* MSigDB Tab */}
      {activeTab === 'msigdb' && (
        <div className="space-y-4">
          <div>
            <button
              onClick={() => msigdbMutation.mutate()}
              disabled={msigdbMutation.isPending || deseqResults.length === 0}
              className="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:bg-gray-300 flex items-center gap-2"
            >
              {msigdbMutation.isPending ? (
                <>
                  <div className="animate-spin rounded-full h-5 w-5 border-b-2 border-white"></div>
                  Analyse en cours...
                </>
              ) : (
                <>
                  <BookOpen className="w-5 h-5" />
                  Lancer l'analyse MSigDB
                </>
              )}
            </button>
          </div>

          {msigdbMutation.isSuccess && (
            <div className="space-y-4">
              <div className="bg-green-50 border border-green-200 rounded-lg p-4">
                <p className="text-green-800 font-medium">
                  ✅ {msigdbMutation.data.n_gene_sets} gene sets enrichis
                </p>
              </div>

              <div className="border border-gray-200 rounded-lg p-4">
                <div className="flex justify-between items-center mb-2">
                  <h3 className="font-semibold">MSigDB Hallmark Gene Sets</h3>
                  <button
                    onClick={() => downloadImage(msigdbMutation.data.dotplot_image, 'msigdb_dotplot.png')}
                    className="text-sm text-blue-600 hover:text-blue-700 flex items-center gap-1"
                  >
                    <Download className="w-4 h-4" />
                    Télécharger
                  </button>
                </div>
                <img src={msigdbMutation.data.dotplot_image} alt="MSigDB Dotplot" className="w-full" />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-2">
                  Sélectionner un gene set pour le running score GSEA
                </label>
                <select
                  value={selectedGeneSet}
                  onChange={(e) => setSelectedGeneSet(e.target.value)}
                  className="w-full px-3 py-2 border border-gray-300 rounded-lg"
                >
                  <option value="">-- Choisir un gene set --</option>
                  {msigdbMutation.data.enrichment_scores?.map((gs: any) => (
                    <option key={gs.index} value={gs.index}>
                      {gs.index}
                    </option>
                  ))}
                </select>
              </div>

              {selectedGeneSet && (
                <button
                  onClick={() => runningScoreMutation.mutate(selectedGeneSet)}
                  disabled={runningScoreMutation.isPending}
                  className="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700"
                >
                  Running Score Plot
                </button>
              )}

              {runningScoreMutation.isSuccess && (
                <div className="border border-gray-200 rounded-lg p-4">
                  <h4 className="font-semibold mb-2">GSEA Running Score - {selectedGeneSet}</h4>
                  <img src={runningScoreMutation.data.running_score_image} alt="Running Score" className="w-full" />
                </div>
              )}
            </div>
          )}
        </div>
      )}
    </div>
  );
};
